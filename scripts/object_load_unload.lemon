			}

			addPatternLoadingCue(0x083d3a)		// Some common object sprites
		}

		addPatternLoadingCue(0x08cf62)		// LBZ2 object sprites
		UnloadObject()
	}
}

// MHZ curled vine bridge
//# address-hook(0x03e952)
//# translated(0x03e93c) end(0x03e9a0)
function void fn03e952()
{
	while (true)
	{
		u16[(A2+=2)-2] = D2.u16
		u16[(A2+=2)-2] = D3.u16
		A2 += 2
		D5 += D4
		D1 = u32[(A7+=4)-4]
		D4 += D1
		--D6.s16
		if (D6.s16 < 0)
			break

		u32[A7-=4] = D1
		D5 = (D5 << 16) + (D5 >> 16)
		D0.u16 = D5.u16
		D5 = (D5 << 16) + (D5 >> 16)
		LookupSinCos()
		D1.s16 >>= 4
		D0.s16 >>= 4
		D2.u16 += D1.u16
		D3.u16 += D0.u16
	}

	D2.u16 = u16[(A7+=2)-2]
	D1.u16 = 0x40
	D3 = 8
	D4.u16 = objA0.position.x.u16
	A2 = A1

	fn03e9ac()

	u16 dx = (objA0.position.x.u16 & 0xff80) - level.despawn_position.x
	if (dx > object_x_threshold)
	{
		if (objA0.respawn_entry)
		{
			A2 = 0xffff0000 + objA0.respawn_entry
			u8[A2] &= ~0x80
		}
		A1 = 0xffff0000 + u16[A0 + 0x46]
		UnloadObjectA1()
		UnloadObject()
	}
}

